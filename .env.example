# Mascope / Karsa server credentials.
#
# Easiest (clone-and-go): copy this to `.env` in the repo root and fill it in.
#     cp .env.example .env
# A project-local .env is git-ignored and found automatically. Or use the shared
# home location instead:
#     mkdir -p ~/.mascope && cp .env.example ~/.mascope/.env
#
# Search order: --env / $MASCOPE_ENV > repo-root .env (or cwd) > ~/.mascope/.env.
# Process environment variables of the same name also work without any file.
#
# Your access token comes from the Mascope web app (account / API settings).

MASCOPE_URL=
MASCOPE_ACCESS_TOKEN=

# Where batch run outputs go. `peaky setup` sets this to THIS workspace's output/
# folder, so the package, .env, and all results live in one place. Leave it unset
# to fall back to ~/peaky-output. Override per-run with `peaky batch --out-dir ...`.
# PEAKY_OUTPUT_DIR=
