__pycache__/
*.pyc

# secrets & data (never commit)
# NB: `.env*` (not `.env.*`) also catches suffix-style creds like .envPROD /
# .envSITE (the dot-form `.env.*` would let those slip through).
.env
.env*
!.env.example
*.parquet
*.npy
*.log
.DS_Store

# local agent settings
.claude/

# generated run outputs (contain campaign data / private identifiers — never commit).
# NB: keep the comment on its OWN line — an inline "# ..." after a pattern becomes part
# of the pattern (git only treats a line STARTING with # as a comment), which silently
# disabled /output/ and let a run folder slip through before.
/output/
/peaky-output/
checkpoints/
*_assignments.xlsx
*_ledger.csv
*_gka.html
*_manifest.json
*_summary.md
